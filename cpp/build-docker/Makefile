_src/main.o: _src/main.cpp.o
.PHONY : _src/main.o

# target to build an object file
_src/main.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/TEMPLATE.exe.dir/build.make CMakeFiles/TEMPLATE.exe.dir/_src/main.cpp.o
.PHONY : _src/main.cpp.o

_src/main.i: _src/main.cpp.i
.PHONY : _src/main.i

# target to preprocess a source file
_src/main.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/TEMPLATE.exe.dir/build.make CMakeFiles/TEMPLATE.exe.dir/_src/main.cpp.i
.PHONY : _src/main.cpp.i

_src/main.s: _src/main.cpp.s
.PHONY : _src/main.s

# target to generate assembly for a file
_src/main.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/TEMPLATE.exe.dir/build.make CMakeFiles/TEMPLATE.exe.dir/_src/main.cpp.s
.PHONY : _src/main.cpp.s

